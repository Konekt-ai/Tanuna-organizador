# =====================================================================
#  Taluna Organizador — variables de entorno
#  Copia este archivo como .env.local y rellena los valores de TU proyecto
#  de Supabase (Project Settings -> API). NUNCA subas .env.local a git.
# =====================================================================

# URL del proyecto Supabase (https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Llave pública "anon" (segura para el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Llave secreta "service_role" — SOLO servidor. NUNCA la pongas en el navegador
# ni con prefijo NEXT_PUBLIC_. Se usa en las rutas API para escribir en la BD y
# subir fotos saltando RLS.
SUPABASE_SERVICE_ROLE_KEY=

# (Opcional) Restringe el acceso a un solo correo. Si lo defines, descomenta el
# bloque correspondiente en lib/auth.js para activarlo.
# ADMIN_EMAIL=
